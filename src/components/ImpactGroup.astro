---
import type { ImpactEntry } from '../data/cv';
import {
  bodyTextClass,
  itemClass,
  metaClass,
  railTitleClass
} from '../lib/cvClasses';

interface Props {
  rail: string;
  items: ImpactEntry[];
}

const { rail, items } = Astro.props as Props;
const baseUrl = Astro.site
  ? new URL(import.meta.env.BASE_URL, Astro.site)
  : undefined;

const resolveHref = (href?: string) => {
  if (!href) return undefined;
  if (/^[a-z][a-z0-9+.-]*:/i.test(href)) return href;
  if (!baseUrl) return href;
  return new URL(href.replace(/^\//, ''), baseUrl).toString();
};
---

<article class:list={[itemClass, 'cv-item--impact']}>
  <div class="cv-item__rail md:col-start-1">
    <h3 class={railTitleClass}>{rail}</h3>
  </div>
  <div class="cv-item__main min-w-0 self-start space-y-2 print:space-y-1.5 md:col-start-2 lg:col-[2/4] print:max-w-none">
    {items.map((item) => (
      <div
        class:list={[
          'entry-row entry-row--impact grid grid-cols-1 gap-y-1 gap-x-[var(--cv-gap)] lg:[grid-template-columns:minmax(0,1fr)_var(--cv-meta)] lg:items-start print:items-start print:gap-y-0.5 print:gap-x-4',
          item.showMetaInline
            ? 'print:grid-cols-1'
            : 'print:grid-cols-[minmax(0,1fr)_auto]'
        ]}
      >
        {item.showMetaInline && (
          <div class:list={['entry-meta', metaClass, 'mb-0.5 text-left lg:hidden print:block print:text-left']}>
            {item.meta}
          </div>
        )}
        <div class:list={['entry-main', bodyTextClass, 'relative pl-5 print:pl-5 before:absolute before:left-0 before:top-[0.78rem] before:h-[0.28rem] before:w-[0.28rem] before:rounded-full before:bg-[var(--accent)] print:before:block']} >
          {resolveHref(item.href) ? (
            <a
              href={resolveHref(item.href)}
              class="cv-entry-bullet block max-w-[47rem] rounded-sm text-slate-700 transition-colors hover:text-[var(--accent)] print:max-w-none"
            >
              <span class="inline min-w-0 underline decoration-[color:color-mix(in_srgb,var(--accent)_55%,transparent)] decoration-1 underline-offset-[0.16em] print:decoration-black/60" set:html={item.html} />
              <span aria-hidden="true" class="ml-1 inline-block text-[0.72em] leading-none text-[var(--accent)] print:text-slate-500">
                ↗
              </span>
            </a>
          ) : (
            <div class="cv-entry-bullet max-w-[47rem] print:max-w-none" set:html={item.html} />
          )}
          {!item.showMetaInline && <div class:list={['entry-meta', metaClass, 'hidden lg:hidden print:hidden']}>{item.meta}</div>}
        </div>
        <div class:list={['entry-meta', metaClass, 'hidden self-start lg:block print:hidden print:mt-0 print:text-right']}>{item.meta}</div>
      </div>
    ))}
  </div>
</article>
