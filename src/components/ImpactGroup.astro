---
import type { ImpactEntry } from '../data/cv';
import {
  bodyTextClass,
  itemClass,
  metaClass,
  railTitleClass
} from '../lib/cvClasses';

interface Props {
  rail: string;
  items: ImpactEntry[];
}

const { rail, items } = Astro.props as Props;

const resolveHref = (href?: string) => {
  if (!href) return undefined;
  if (/^[a-z][a-z0-9+.-]*:/i.test(href)) return href;
  const relativeHref = href.replace(/^\//, '');
  if (import.meta.env.DEV) return relativeHref;
  return new URL(relativeHref, new URL(import.meta.env.BASE_URL, Astro.site)).toString();
};

// Mark each entry with whether its year should be shown in the right meta column.
// Show only on the first entry of each year-group so consecutive same-year items
// cluster visually without repeating the year. cv.ts must be in descending year order.
const rendered = items.map((item, idx) => ({
  item,
  showYear: idx === 0 || items[idx - 1].meta !== item.meta
}));
---

<article class:list={[itemClass, 'cv-item--impact']}>
  <div class="cv-item__rail md:col-start-1">
    <h3 class={railTitleClass}>{rail}</h3>
  </div>
  <div class="cv-item__main min-w-0 self-start space-y-2 print:space-y-1.5 md:col-[2/-1] print:max-w-none">
    {rendered.map(({ item, showYear }) => (
      <div
        class="entry-row entry-row--impact grid grid-cols-1 gap-y-1 gap-x-[var(--cv-gap)] lg:[grid-template-columns:minmax(0,1fr)_var(--cv-meta)] lg:items-start print:[grid-template-columns:minmax(0,1fr)_var(--cv-meta)] print:items-start print:gap-y-0.5"
      >
        {showYear && (
          <div class:list={['entry-meta entry-meta--inline', metaClass, 'mb-0.5 text-left lg:hidden print:hidden']}>
            {item.meta}
          </div>
        )}
        <div class:list={['entry-main relative pl-5 print:pl-5 before:absolute before:left-0 before:top-[0.78rem] before:h-[0.28rem] before:w-[0.28rem] before:rounded-full before:bg-[var(--accent)] print:before:block', bodyTextClass]}>
          {resolveHref(item.href) ? (
            <a
              href={resolveHref(item.href)}
              class="cv-entry-bullet block max-w-[47rem] rounded-sm text-[var(--ink-strong)] transition-colors hover:text-[var(--accent)] print:max-w-none"
            >
              <span class="inline min-w-0 underline decoration-[color:color-mix(in_srgb,var(--accent)_55%,transparent)] decoration-1 underline-offset-[0.16em] print:decoration-black/60" set:html={item.html} />
              <span aria-hidden="true" class="ml-1 inline-block text-[0.72em] leading-none text-[var(--accent)] print:hidden">
                ↗
              </span>
            </a>
          ) : (
            <div class="cv-entry-bullet max-w-[47rem] print:max-w-none" set:html={item.html} />
          )}
        </div>
        <div class:list={['entry-meta entry-meta--column', metaClass, 'hidden self-start lg:block print:block print:mt-0 print:text-right']}>
          {showYear ? item.meta : ''}
        </div>
      </div>
    ))}
  </div>
</article>
