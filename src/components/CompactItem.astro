---
import type { CompactItem } from '../data/cv';
import {
  bodyTextClass,
  itemClass,
  leadTextClass,
  metaClass,
  railTitleClass,
  subBulletListClass
} from '../lib/cvClasses';

interface Props {
  item: CompactItem;
  variant?: 'project' | 'education';
}

const { item, variant = 'project' } = Astro.props as Props;
---

<article class:list={[itemClass, 'cv-item--compact', `cv-item--${variant}`]}>
  <div class="cv-item__rail md:col-start-1">
    <h3 class={railTitleClass}>{item.rail}</h3>
  </div>
  <div class="cv-item__main min-w-0 self-start max-w-[47rem] print:max-w-none md:col-start-2">
    {item.lead && <p class:list={['cv-item__lead', leadTextClass, 'm-0 md:pl-0']} set:html={item.lead} />}
    <div class:list={['entry-meta', metaClass, 'mt-0.5 lg:hidden print:hidden']}>{item.meta}</div>
    {item.details && (
      <ul class:list={['cv-sublist', subBulletListClass, item.lead ? 'mt-2 print:mt-1.5' : 'mt-0']}>
        {item.details.map((detail) => (
          <li set:html={detail} />
        ))}
      </ul>
    )}
    {item.bullets && (
      <ul class:list={['cv-list', 'm-0 list-none space-y-2 print:space-y-1.5 p-0', item.lead || item.details ? 'mt-2 print:mt-1.5' : 'mt-0']} role="list">
        {item.bullets.map((bullet) => (
          <li class:list={['relative pl-4', bodyTextClass]}>
            <span aria-hidden="true" class="absolute left-0 top-[0.72rem] h-[0.28rem] w-[0.28rem] rounded-full bg-[var(--accent)]"></span>
            <span class="block min-w-0" set:html={bullet} />
          </li>
        ))}
      </ul>
    )}
  </div>
  <div class:list={['cv-item__meta', metaClass, 'hidden self-start lg:col-start-3 lg:block print:col-start-3 print:block']}>
    {item.meta}
  </div>
</article>
