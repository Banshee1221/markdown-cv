---
import { Globe, Mail, MapPin } from 'lucide';
import { siGithub } from 'simple-icons';

interface Props {
  kind: 'email' | 'website' | 'linkedin' | 'github' | 'location';
}

const { kind } = Astro.props as Props;
const mailPath = String(Mail[0][1].d);
const globePath = String(Globe[1][1].d);
const globeMeridianPath = String(Globe[2][1].d);
const mapPinPath = String(MapPin[0][1].d);
const githubSvg = siGithub.svg.replace(
  '<svg ',
  '<svg class="h-4 w-4 shrink-0 text-[var(--accent)]" fill="currentColor" '
);
---

<span aria-hidden="true" class="inline-flex h-4 w-4 shrink-0 items-center justify-center text-[var(--accent)]">
  {kind === 'email' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.9" class="h-4 w-4">
      <rect x="2" y="4" width="20" height="16" rx="2" />
      <path d={mailPath} />
    </svg>
  )}
  {kind === 'website' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" class="h-4 w-4">
      <circle cx="12" cy="12" r="10" />
      <path d={globePath} />
      <path d={globeMeridianPath} />
    </svg>
  )}
  {kind === 'location' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" class="h-4 w-4">
      <path d={mapPinPath} />
      <circle cx="12" cy="10" r="3" />
    </svg>
  )}
  {kind === 'github' && (
    <span class="block" set:html={githubSvg} />
  )}
  {kind === 'linkedin' && (
    <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7">
      <rect x="3" y="3" width="18" height="18" rx="4" />
      <path d="M8.2 10.2v7" />
      <path d="M8.2 7.7h.1" />
      <path d="M12 10.4v6.8" />
      <path d="M12 13c0-1.5 1-2.6 2.5-2.6 1.7 0 2.6 1.1 2.6 3v4" />
      <text x="6.8" y="16.9" fill="currentColor" font-family="Inter, Arial, sans-serif" font-size="6.6" font-weight="700">in</text>
    </svg>
  )}
</span>
